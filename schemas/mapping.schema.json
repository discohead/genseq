{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://genseq.dev/schemas/mapping.schema.json",
  "title": "GenSeq MIDI Input Mapping",
  "description": "Map MIDI input to pattern parameters",
  "type": "object",
  "required": ["source", "target"],
  "properties": {
    "source": {
      "type": "object",
      "description": "MIDI input source",
      "required": ["device", "type"],
      "properties": {
        "device": {
          "type": "string",
          "description": "MIDI input device name"
        },
        "type": {
          "type": "string",
          "description": "MIDI message type",
          "enum": ["cc", "note", "aftertouch", "pitchbend"]
        },
        "channel": {
          "type": "integer",
          "minimum": 1,
          "maximum": 16
        },
        "cc": {
          "type": "integer",
          "description": "CC number for CC messages",
          "minimum": 0,
          "maximum": 127
        },
        "note": {
          "type": "integer",
          "description": "Note number for note messages",
          "minimum": 0,
          "maximum": 127
        }
      }
    },
    "target": {
      "type": "object",
      "description": "Pattern parameter target",
      "required": ["pattern", "parameter"],
      "properties": {
        "pattern": {
          "type": "string",
          "description": "Target pattern ID"
        },
        "parameter": {
          "type": "string",
          "description": "Parameter name to control"
        }
      }
    },
    "transform": {
      "type": "object",
      "description": "Input transformation",
      "properties": {
        "min": {
          "type": "number",
          "description": "Minimum output value"
        },
        "max": {
          "type": "number",
          "description": "Maximum output value"
        },
        "curve": {
          "type": "string",
          "description": "Scaling curve",
          "enum": ["linear", "exponential", "logarithmic"],
          "default": "linear"
        },
        "smooth": {
          "type": "number",
          "description": "Smoothing time in ms",
          "minimum": 0,
          "maximum": 1000,
          "default": 0
        }
      }
    },
    "enabled": {
      "type": "boolean",
      "default": true
    }
  }
}
