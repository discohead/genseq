{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://genseq.dev/schemas/patterns/probability.schema.json",
  "title": "Probability Pattern Configuration",
  "description": "Configuration for probability-based pattern generation",
  "type": "object",
  "required": ["probability", "density", "note", "velocity", "duration"],
  "properties": {
    "probability": {
      "type": "number",
      "description": "Trigger probability (0.0 = never, 1.0 = always)",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "density": {
      "type": "integer",
      "description": "Notes per bar (4 = quarter notes, 8 = eighth notes, 16 = sixteenth notes)",
      "enum": [1, 2, 4, 8, 16, 32, 64],
      "default": 16
    },
    "note": {
      "type": "integer",
      "description": "MIDI note number",
      "minimum": 0,
      "maximum": 127,
      "default": 60
    },
    "velocity": {
      "oneOf": [
        {
          "type": "integer",
          "description": "Fixed MIDI velocity",
          "minimum": 1,
          "maximum": 127,
          "default": 100
        },
        {
          "type": "array",
          "description": "Array of velocities for variation",
          "items": {
            "type": "integer",
            "minimum": 1,
            "maximum": 127
          },
          "minItems": 1,
          "maxItems": 64
        }
      ]
    },
    "duration": {
      "type": "number",
      "description": "Note duration in beats",
      "minimum": 0.01,
      "maximum": 16,
      "default": 0.25
    },
    "seed": {
      "type": "integer",
      "description": "Optional seed for deterministic randomness",
      "minimum": 0
    },
    "velocityModulation": {
      "type": "boolean",
      "description": "Future: modulate velocity by probability",
      "default": false
    }
  }
}
