{
  "$schema": "../../../schemas/scene.schema.json",
  "id": "intro",
  "name": "Intro Scene",
  "description": "Minimal techno - kick only with sparse bass",
  "activePatterns": ["kick-bass"],
  "patternOverrides": {
    "kick-bass": {
      "kick": {
